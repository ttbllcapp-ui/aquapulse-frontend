{
  "expo": {
    "name": "AquaPulse — Water Tracker",
    "slug": "aquapulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aquapulse",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.ttbinternationalllc.aquapulse",
      "supportsTablet": true,
      "buildNumber": "2",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Send daily water reminders so you stay hydrated",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleLocalizations": [
          "en",
          "tr",
          "de",
          "fr",
          "es",
          "it",
          "pt",
          "nl",
          "ru",
          "ar",
          "ja",
          "ko",
          "zh",
          "hi",
          "id",
          "vi",
          "th",
          "pl"
        ],
        "CFBundleDevelopmentRegion": "en"
      }
    },
    "android": {
      "package": "com.ttbinternationalllc.aquapulse",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1E3A8A"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#1E3A8A"
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#3B82F6"
        }
      ],
      "expo-localization",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supportEmail": "info@ttbinternationalllc.com",
      "companyName": "TTB International LLC",
      "privacyUrl": "https://ttbllcapp-ui.github.io/aquapulse-legal/privacy.html",
      "termsUrl": "https://ttbllcapp-ui.github.io/aquapulse-legal/terms.html",
      "supportUrl": "https://ttbllcapp-ui.github.io/aquapulse-legal/support.html",
      "router": {},
      "eas": {
        "projectId": "24d46cbc-74e1-4de9-ab2b-7dd9f873caf1"
      }
    }
  }
}
