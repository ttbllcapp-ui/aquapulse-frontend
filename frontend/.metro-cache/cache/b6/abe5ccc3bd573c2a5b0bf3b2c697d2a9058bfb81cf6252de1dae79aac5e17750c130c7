{"dependencies":[],"output":[{"data":{"code":"__d(function (global, require, _$$_IMPORT_DEFAULT, _$$_IMPORT_ALL, module, exports, _dependencyMap) {\n  \"use strict\";\n\n  Object.defineProperty(exports, '__esModule', {\n    value: true\n  });\n  exports.getQuoteForDay = getQuoteForDay;\n  exports.getRandomQuote = getRandomQuote;\n  // Motivational, non-medical quotes — 20 entries per language, 18 languages.\n  // All previous medical-claim quotes have been removed.\n  const QUOTES = {\n    en: ['Small sips, big changes. Every drop counts.', 'Your body is your ocean — keep it flowing.', 'Consistency beats perfection. Drink today.', 'Water is the foundation of every good habit.', 'One glass at a time. You\\'ve got this.', 'Hydration is self-care at its simplest.', 'Progress, not perfection. Keep going.', 'Every habit starts with a single sip.', 'Your future self will thank you.', 'Make hydration your superpower today.', 'A hydrated mind thinks clearer.', 'Today\\'s water is tomorrow\\'s energy.', 'You are 60% water — honor that.', 'Drink up, show up, never give up.', 'The best time to drink water is now.', 'Little by little, the ocean fills.', 'Stay consistent, stay hydrated.', 'Your goals start with a glass of water.', 'Fuel your day the natural way.', 'Sip by sip, day by day.'],\n    tr: ['Küçük yudumlar, büyük değişimler. Her damla sayılır.', 'Vücudun senin okyanusun — akışında kalmasını sağla.', 'Tutarlılık mükemmellikten önemlidir. Bugün iç.', 'Su, her iyi alışkanlığın temelidir.', 'Bir bardak, bir adım. Sen başarırsın.', 'Hidrasyon, en sade haliyle öz bakımdır.', 'Mükemmel değil, ilerleme önemli. Devam et.', 'Her alışkanlık tek bir yudumla başlar.', 'Gelecekteki sen sana teşekkür edecek.', 'Hidrasyonu bugün süper gücün yap.', 'İyi hidrate bir zihin daha net düşünür.', 'Bugünün suyu yarının enerjisidir.', '%60’ın sudan — buna saygı göster.', 'Su iç, ortaya çık, asla pes etme.', 'Su içmenin en iyi zamanı şu an.', 'Damla damla okyanus olur.', 'Tutarlı kal, hidrate 